#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT="$ROOT_DIR/bin/omarchy-environment-apply"

usage() {
  cat <<'EOF'
test-env

Validate an environment.json or repo input with mocked Omarchy/package commands.

Usage:
  ./scripts/test-env /path/to/environment.json
  ./scripts/test-env github:owner/environment-repo

This runs omarchy-environment-apply with --dry-run --verbose, a temporary HOME,
and fake Omarchy/package commands. Remote repo inputs still use real curl.
EOF
}

die() {
  printf '[test-env:error] %s\n' "$*" >&2
  exit 1
}

[[ "${1:-}" != "--help" && "${1:-}" != "-h" ]] || { usage; exit 0; }
[[ $# -eq 1 ]] || { usage; exit 1; }

INPUT="$1"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

TEST_HOME="$TMP_DIR/home"
STUB_DIR="$TMP_DIR/stubs"
LOG_FILE="$TMP_DIR/calls.log"

mkdir -p "$TEST_HOME" "$STUB_DIR"

create_stub() {
  local name="$1"
  cat >"$STUB_DIR/$name" <<EOF
#!/bin/sh
echo "$name \$*" >>"$LOG_FILE"
exit 0
EOF
  chmod +x "$STUB_DIR/$name"
}

for cmd in omarchy-theme-install omarchy-theme-set omarchy-pkg-add omarchy-pkg-drop git nvm; do
  create_stub "$cmd"
done

PATH="$STUB_DIR:$PATH" HOME="$TEST_HOME" "$SCRIPT" "$INPUT" --dry-run --verbose

printf '[test-env] Temporary HOME: %s\n' "$TEST_HOME"
printf '[test-env] Mocked command log:\n'
if [[ -s "$LOG_FILE" ]]; then
  sed 's/^/[test-env]   /' "$LOG_FILE"
else
  printf '[test-env]   No external Omarchy/package commands were invoked.\n'
fi
